<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.itoms.mapper.DataScopeMapper">

    <select id="selectByRoleId" resultType="com.company.itoms.entity.DataScopeEntity">
        SELECT * FROM sys_data_scope WHERE role_id = #{roleId}
    </select>

    <delete id="deleteByRoleId">
        DELETE FROM sys_data_scope WHERE role_id = #{roleId}
    </delete>

</mapper>
